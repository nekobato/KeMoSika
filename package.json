{
  "name": "kemosika",
  "private": true,
  "version": "0.0.1",
  "author": {
    "name": "nekobato",
    "email": "nekobato@gmail.com",
    "url": "https://nekobato.net"
  },
  "license": "MIT",
  "description": "Keyboard/Mouse Input Visualizer",
  "scripts": {
    "postinstall": "rm -rf node_modules/electron/dist && node node_modules/electron/install.js",
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --config electron-builder.config.cjs",
    "release": "electron-vite build && electron-builder --publish always",
    "build:icon": "electron-icon-builder --input=./public/icon.png --output=./public",
    "build:win": "pnpm run build && electron-builder --win --config --x64",
    "build:mac": "pnpm run build && electron-builder --mac --config",
    "build:linux": "pnpm run build && electron-builder --linux --config",
    "test:e2e:build": "electron-vite build",
    "test:e2e:typecheck": "tsc --noEmit -p tsconfig.playwright.json",
    "test:e2e": "pnpm run test:e2e:typecheck && pnpm run test:e2e:build && playwright test",
    "test:e2e:headed": "pnpm run test:e2e:typecheck && pnpm run test:e2e:build && playwright test --headed",
    "test:e2e:ui": "pnpm run test:e2e:typecheck && pnpm run test:e2e:build && playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "docs:dev": "vitepress dev doc",
    "docs:build": "vitepress build doc",
    "docs:preview": "vitepress preview doc",
    "wdio": "wdio run ./wdio.conf.ts",
    "typecheck": "tsc --noEmit && vue-tsc --noEmit",
    "lint": "pnpm run typecheck"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.24.0"
  },
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "electron-store": "11.0.2",
    "fflate": "0.8.3",
    "font-list": "2.1.0",
    "node-gyp-build": "4.8.4",
    "uiohook-napi": "1.5.5"
  },
  "devDependencies": {
    "@iconify/vue": "5.0.1",
    "@playwright/test": "1.60.0",
    "@primeuix/themes": "2.0.3",
    "@primevue/themes": "4.5.4",
    "@sentry/electron": "7.13.0",
    "@types/node": "25.9.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vueuse/core": "14.3.0",
    "@wdio/cli": "9.27.2",
    "@wdio/local-runner": "9.27.2",
    "@wdio/mocha-framework": "9.27.2",
    "@wdio/spec-reporter": "9.27.2",
    "dotenv": "17.4.2",
    "electron": "42.3.0",
    "electron-builder": "26.13.0",
    "electron-icon-builder": "2.0.1",
    "electron-vite": "5.0.0",
    "fs-extra": "11.3.5",
    "nanoid": "5.1.11",
    "pinia": "3.0.4",
    "playwright": "1.60.0",
    "primeflex": "4.0.0",
    "primevue": "4.5.5",
    "sass-embedded": "1.100.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plugin-electron": "1.0.0",
    "vite-plugin-electron-renderer": "1.0.0",
    "vite-svg-loader": "5.1.1",
    "vue": "3.5.35",
    "vue-router": "5.1.0",
    "vue-tsc": "3.3.3",
    "vue3-moveable": "0.28.0",
    "vue3-selecto": "1.12.3",
    "wdio-electron-service": "9.2.1"
  },
  "main": "./out/main/index.mjs"
}
